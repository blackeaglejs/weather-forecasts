<%= form_with(model: location, class: "space-y-8") do |form| %>
  <% if location.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(location.errors.count, "error") %> prohibited this location from being saved:</h2>

      <ul class="list-disc ml-6">
        <% location.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="px-6 py-6 grid grid-cols-2 gap-x-8 gap-y-5">
  <div class="my-5">
    <%= form.label :address_one %>
    <%= form.text_field :address_one, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": location.errors[:address_one].none?, "border-red-400 focus:outline-red-600": location.errors[:address_one].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :address_two %>
    <%= form.text_field :address_two, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": location.errors[:address_two].none?, "border-red-400 focus:outline-red-600": location.errors[:address_two].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :city %>
    <%= form.text_field :city, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": location.errors[:city].none?, "border-red-400 focus:outline-red-600": location.errors[:city].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :province %>
    <%= form.text_field :province, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": location.errors[:province].none?, "border-red-400 focus:outline-red-600": location.errors[:province].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :postal_code %>
    <%= form.text_field :postal_code, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": location.errors[:postal_code].none?, "border-red-400 focus:outline-red-600": location.errors[:postal_code].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :country %>
    <%= form.select :country, @countries, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": location.errors[:country].none?, "border-red-400 focus:outline-red-600": location.errors[:country].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
  </div>
<% end %>
